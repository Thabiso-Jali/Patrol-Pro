# Environment Configuration for Patrol Pro Backend

# Database
DATABASE_URL=sqlite:///./patrol_pro.db
# For PostgreSQL production: DATABASE_URL=postgresql://user:password@localhost:5432/patrol_pro

# Security
SECRET_KEY=change-this-to-a-very-long-random-production-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SESSION_IDLE_TIMEOUT_MINUTES=30

# Rate limiting
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Server
HOST=127.0.0.1
PORT=8000
DEBUG=True
RELOAD=True

# CORS
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://127.0.0.1:3000", "http://127.0.0.1:3001"]

# Security hardening
ENABLE_SECURITY_HEADERS=True
ENABLE_RATE_LIMITING=True

# API Documentation
API_TITLE=Patrol Pro API
API_VERSION=1.0.0
API_DESCRIPTION=Professional security patrol management platform
